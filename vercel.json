{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "rewrites": [
    {
      "source": "/test",
      "destination": "/index.html"
    },
    {
      "source": "/test/",
      "destination": "/index.html"
    },
    {
      "source": "/test/(.*)",
      "destination": "/$1"
    }
  ]
}
